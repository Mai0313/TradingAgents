/* TradingAgents Textual TUI styles. */

Screen {
    background: $background;
    color: $foreground;
}

/* ==================== Setup screen ==================== */

SetupScreen {
    align: center middle;
}

#setup-scroll {
    width: 80%;
    max-width: 100;
    height: 90%;
    border: round $primary;
    padding: 1 2;
}

#setup-title {
    text-style: bold;
    color: $accent;
    padding: 0 0 1 0;
}

#setup-hint {
    color: $text-muted;
    padding: 0 0 1 0;
}

.form-row {
    layout: horizontal;
    height: auto;
    padding: 0 0 1 0;
}

.form-label {
    width: 30;
    height: auto;
    padding: 1 1 0 0;
    text-align: right;
    color: $text-muted;
}

.form-input {
    width: 1fr;
    height: auto;
}

.form-checkboxes {
    layout: horizontal;
    height: 1;
    width: 1fr;
}

.form-checkboxes Checkbox {
    width: auto;
    margin: 0 2 0 0;
    height: 1;
    border: none;
    padding: 0;
}

.form-checkboxes Checkbox:focus {
    border: none;
}

#actions {
    layout: horizontal;
    height: auto;
    padding: 1 0 0 0;
    align-horizontal: right;
}

#actions Button {
    margin: 0 0 0 1;
}

#setup-error {
    color: $error;
    padding: 1 0 0 0;
}

/* ==================== Run screen ==================== */

RunScreen {
    layout: vertical;
}

#run-header {
    dock: top;
    height: auto;
    max-height: 16;
    padding: 0 1;
    border: none;
}

#run-body {
    layout: horizontal;
    height: 1fr;
}

#phase-sidebar {
    width: 32;
    height: 1fr;
    border-right: solid $primary 50%;
    padding: 1 1;
    overflow-y: auto;
}

#phase-sidebar-title {
    text-style: bold;
    color: $accent;
    padding: 0 0 1 0;
}

.phase-row {
    layout: horizontal;
    height: 1;
    padding: 0;
}

.phase-icon {
    width: 3;
    height: 1;
    text-align: left;
}

.phase-label {
    width: 1fr;
    height: 1;
}

.phase-progress {
    width: auto;
    height: 1;
    padding: 0 0 0 1;
    color: $text-muted;
}

.phase-row.-pending .phase-icon {
    color: $text-muted;
}
.phase-row.-pending .phase-label {
    color: $text-muted;
}
.phase-row.-running .phase-icon {
    color: $warning;
    text-style: bold;
}
.phase-row.-running .phase-label {
    color: $warning;
    text-style: bold;
}
.phase-row.-done .phase-icon {
    color: $success;
}
.phase-row.-done .phase-label {
    color: $foreground;
}

#messages {
    width: 1fr;
    height: 1fr;
    padding: 0 1;
}

#run-status {
    dock: bottom;
    height: 1;
    padding: 0 1;
    background: $primary 20%;
    color: $foreground;
}
